// 文章卡片磨砂玻璃质感（替换原白色背景）
.post.white-box {
  /* 1. 底色：不再用纯白，而是用带有 2% 灰度的冷色，防止在亮色壁纸下与背景混在一起 */
  background: rgba(250, 251, 252, 0.55) !important;
  
  /* 2. 核心滤镜：
     - blur(20px): 模糊度稍微拉高，减少背景复杂线条对文字的干扰
     - contrast(0.85): 降低背景对比度！这是护眼关键，让背景的风景变得柔和、不刺眼
     - brightness(1.05): 微量提亮
  */
  backdrop-filter: blur(20px) saturate(130%) contrast(0.85) brightness(1.05) !important;
  -webkit-backdrop-filter: blur(20px) saturate(130%) contrast(0.85) brightness(1.05) !important;

  /* 3. 去掉 text-shadow，直接上纯净颜色 */
  color: #222222 !important; 
  font-weight: 500;
  letter-spacing: 0.01em; /* 微调字间距，提升可读性 */

  /* 4. 视觉重心：用双重边框来定义盒子的存在感，而不是靠文字阴影 */
  border: 1px solid rgba(255, 255, 255, 0.1) !important; /* 不明显的亮边 */
  box-shadow: 
    0 10px 40px rgba(0, 0, 0, 0.05),        /* 柔和的外阴影 */
    inset 0 0 0 1px rgba(0, 0, 0, 0.03);    /* 极细的内轮廓线，给亮色背景兜底 */

  border-radius: 18px;
  padding: 24px;
}



// ---
// 可选：文章内描述区同步磨砂（防止内部背景冲突）
.post .article-desc
  background: transparent !important
  backdrop-filter: none !important
  
// 顶部导航栏 · 磨砂玻璃
// 顶部 Header · 磨砂玻璃（最终正确层）
#l_header.l_header
  background rgba(255, 255, 255, 0.65) !important
  background-color rgba(255, 255, 255, 0.65) !important
  background-image none !important

  backdrop-filter blur(10px) saturate(120%)
  -webkit-backdrop-filter blur(10px) saturate(120%)

  border-bottom 1px solid rgba(255, 255, 255, 0.35)
  box-shadow 0 6px 24px rgba(0, 0, 0, 0.08)
  
// 侧边栏 Widget · 磨砂玻璃
#l_side .widget
  background rgba(255, 255, 255, 0.35) !important
  background-color rgba(255, 255, 255, 0.35) !important
  background-image none !important

  backdrop-filter blur(14px) saturate(120%)
  -webkit-backdrop-filter blur(14px) saturate(120%)

  // border 1px solid rgba(255, 255, 255, 0.35)
  border-radius 16px

  box-shadow 0 6px 24px rgba(0, 0, 0, 0.08)